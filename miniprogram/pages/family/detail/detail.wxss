.detail-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding-bottom: 40rpx;
}

/* 家庭信息头 */
.family-header {
  background: #fff;
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.family-icon-lg {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.family-name-lg {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
}

.family-count {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

.rename-btn {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #3498DB;
}

/* 分区 */
.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.section-title {
  font-size: 26rpx;
  color: #95A5A6;
  padding: 24rpx 28rpx 12rpx;
  font-weight: bold;
}

/* 成员项 */
.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.member-avatar-emoji {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F0, #A8E6CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name {
  font-size: 28rpx;
  color: #2C3E50;
}

.role-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.tag-admin {
  background: #FFF8E1;
  color: #F39C12;
}

.tag-member {
  background: #E8F8F0;
  color: #2ECC71;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-transfer {
  font-size: 24rpx;
  color: #3498DB;
}

.action-remove {
  font-size: 24rpx;
  color: #E74C3C;
}

/* 操作按钮 */
.action-section {
  padding: 24rpx;
}

.action-btn {
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.invite-btn {
  background: #fff;
  color: #2C3E50;
}

.leave-btn {
  background: #fff;
  color: #E74C3C;
}

.danger-btn {
  background: #fff;
  color: #E74C3C;
  font-size: 26rpx;
}

.personal-note {
  margin: 40rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #95A5A6;
}
