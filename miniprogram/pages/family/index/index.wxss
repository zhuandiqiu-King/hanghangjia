.family-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 24rpx 24rpx 160rpx;
}

.family-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.family-card.active {
  border: 2rpx solid #2ECC71;
}

.card-main {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
}

.family-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 40rpx;
  background: #F5F0EB;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.family-info {
  flex: 1;
}

.family-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C3E50;
  display: block;
}

.family-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 12rpx;
}

.role-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.badge-admin {
  background: #FFF8E1;
  color: #F39C12;
}

.badge-member {
  background: #E8F8F0;
  color: #2ECC71;
}

.member-count {
  font-size: 22rpx;
  color: #95A5A6;
}

.arrow {
  font-size: 36rpx;
  color: #BDC3C7;
}

.card-action {
  border-top: 1rpx solid #F5F5F5;
  padding: 20rpx 28rpx;
  text-align: center;
}

.switch-btn {
  font-size: 26rpx;
  color: #3498DB;
  font-weight: 500;
}

.switch-btn:active {
  opacity: 0.7;
}

.current-tag {
  font-size: 24rpx;
  color: #2ECC71;
  font-weight: 500;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.create-wrap {
  padding: 20rpx 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F5F0EB;
}

.create-btn {
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: #fff;
  color: #2C3E50;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.create-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
