<view class="dashboard-page">
  <!-- 顶部欢迎区 -->
  <view class="welcome-section">
    <view class="welcome-left">
      <text class="welcome-hi">Hi，{{loggedIn ? (nickname || '主人') : '欢迎来到夯夯家'}}</text>
      <text class="welcome-date">{{dateText}}</text>
    </view>
    <view class="welcome-right">
      <text wx:if="{{loggedIn}}" class="family-tag">{{familyName || '我的家'}}</text>
      <text wx:else class="family-tag login-tag" bindtap="goLogin">点击登录</text>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view wx:if="{{!loggedIn}}" class="section">
    <view class="guest-card" bindtap="goLogin">
      <text class="guest-icon">👋</text>
      <text class="guest-title">登录后解锁全部功能</text>
      <text class="guest-desc">管理家庭任务、浇水提醒、购物清单等</text>
    </view>
  </view>

  <!-- 今日任务（登录后显示） -->
  <view wx:if="{{loggedIn}}" class="section">
    <view class="section-header">
      <text class="section-title">今日任务</text>
      <text class="section-count">{{todayTasks.length}} 项</text>
    </view>

    <view wx:if="{{todayTasks.length}}" class="task-list">
      <view
        wx:for="{{todayTasks}}"
        wx:key="id"
        class="task-item {{item.done ? 'task-done' : ''}}"
        bindtap="toggleTask"
        data-idx="{{index}}"
      >
        <view class="task-check">{{item.done ? '✅' : '⬜'}}</view>
        <view class="task-info">
          <text class="task-icon">{{item.icon}}</text>
          <text class="task-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">今天没有待办任务</text>
    </view>
  </view>

  <!-- 本周概览（登录后显示） -->
  <view wx:if="{{loggedIn}}" class="section">
    <view class="section-header">
      <text class="section-title">本周概览</text>
    </view>
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-num">{{weekDone}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{weekPending}}</text>
        <text class="stat-label">待完成</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{familyMembers}}</text>
        <text class="stat-label">家庭成员</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">快捷入口</text>
    </view>
    <view class="shortcut-row">
      <view class="shortcut-item" bindtap="goTo" data-url="/pages/plant/watering/watering">
        <view class="shortcut-icon">💧</view>
        <text class="shortcut-name">浇水</text>
      </view>
      <view class="shortcut-item" bindtap="goTo" data-url="/pages/tools/tools">
        <view class="shortcut-icon">📋</view>
        <text class="shortcut-name">购物清单</text>
      </view>
      <view class="shortcut-item" bindtap="goTo" data-url="/pages/tools/tools">
        <view class="shortcut-icon">📖</view>
        <text class="shortcut-name">学习计划</text>
      </view>
      <view class="shortcut-item" bindtap="goTo" data-url="/pages/tools/tools">
        <view class="shortcut-icon">🍳</view>
        <text class="shortcut-name">烹饪</text>
      </view>
    </view>
  </view>

  <!-- AI 悬浮按钮 -->
  <view class="ai-fab" bindtap="goToChat">
    <text class="ai-fab-icon">💬</text>
  </view>
</view>
