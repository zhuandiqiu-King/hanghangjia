<view class="chat-page">
  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollId}}"
    scroll-with-animation
  >
    <view
      wx:for="{{messages}}"
      wx:key="index"
      id="msg-{{index}}"
      class="message-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}"
      bindlongpress="handleCopy"
      data-idx="{{index}}"
    >
      <!-- AI 头像 -->
      <view wx:if="{{item.role === 'ai'}}" class="avatar avatar-ai">🌱</view>

      <!-- 消息气泡 -->
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
        <text>{{item.content}}</text>
      </view>

      <!-- 用户头像 -->
      <view wx:if="{{item.role === 'user'}}" class="avatar avatar-user">😊</view>
    </view>

    <!-- 加载动画 -->
    <view wx:if="{{loading}}" class="message-row msg-left">
      <view class="avatar avatar-ai">🌱</view>
      <view class="bubble bubble-ai loading-bubble">
        <view class="dot-loading">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <!-- 底部留白 -->
    <view class="scroll-bottom"></view>
  </scroll-view>

  <!-- 底部输入框 -->
  <view class="input-bar">
    <input
      class="msg-input"
      placeholder="输入消息..."
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="handleSend"
      disabled="{{loading}}"
    />
    <button
      class="send-btn {{inputValue.trim() && !loading ? 'send-active' : ''}}"
      bindtap="handleSend"
      disabled="{{!inputValue.trim() || loading}}"
    >
      发送
    </button>
  </view>
</view>
