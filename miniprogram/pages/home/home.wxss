.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f5f0;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 0;
}

.scroll-bottom {
  height: 20rpx;
}

/* 消息行 */
.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, #a5d6a7, #66bb6a);
  margin-right: 16rpx;
}

.avatar-user {
  background: linear-gradient(135deg, #90caf9, #42a5f5);
  margin-left: 16rpx;
}

/* 气泡 */
.bubble {
  max-width: 65%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble-ai {
  background: #fff;
  color: #333;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.bubble-user {
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: #fff;
  border-top-right-radius: 6rpx;
}

/* 加载动画 */
.loading-bubble {
  padding: 24rpx 36rpx;
}

.dot-loading {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #999;
  animation: dotBounce 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
}

/* 语音/键盘切换 */
.voice-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 36rpx;
  background: #ccc;
  color: #fff;
  padding: 0;
  border: none;
}

.send-active {
  background: linear-gradient(135deg, #66bb6a, #43a047);
}

/* 语音按钮 */
.voice-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 36rpx;
}

.voice-btn:active,
.voice-btn-active {
  background: #e0e0e0;
  color: #e53935;
}
