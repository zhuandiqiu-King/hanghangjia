.dashboard-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 24rpx 120rpx;
}

/* 欢迎区 */
.welcome-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.welcome-hi {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
}

.welcome-date {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 6rpx;
}

.family-tag {
  font-size: 24rpx;
  color: #27AE60;
  background: #E8F8F0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.login-tag {
  color: #fff;
  background: #2ECC71;
}

/* 未登录引导卡片 */
.guest-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.guest-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.guest-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.guest-desc {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
}

/* 通用 section */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2C3E50;
}

.section-count {
  font-size: 24rpx;
  color: #95A5A6;
}

/* 任务列表 */
.task-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
  transition: opacity 0.2s;
}

.task-item:last-child {
  border-bottom: none;
}

.task-done {
  opacity: 0.5;
}

.task-done .task-name {
  text-decoration: line-through;
}

.task-check {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.task-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.task-name {
  font-size: 28rpx;
  color: #2C3E50;
}

/* 空状态 */
.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 26rpx;
  color: #95A5A6;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2ECC71;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #95A5A6;
  margin-top: 6rpx;
}

/* 快捷入口 */
.shortcut-row {
  display: flex;
  gap: 16rpx;
}

.shortcut-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.shortcut-item:active {
  transform: scale(0.95);
}

.shortcut-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.shortcut-name {
  display: block;
  font-size: 24rpx;
  color: #2C3E50;
  font-weight: 500;
}

/* AI 悬浮按钮 */
.ai-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(46, 204, 113, 0.4);
  z-index: 100;
  transition: transform 0.2s;
}

.ai-fab:active {
  transform: scale(0.9);
}

.ai-fab-icon {
  font-size: 44rpx;
}
