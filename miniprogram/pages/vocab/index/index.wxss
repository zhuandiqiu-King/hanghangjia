.vocab-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

/* 小朋友选择区 */
.child-section {
  padding: 24rpx 0;
}

.child-scroll {
  white-space: nowrap;
}

.child-list {
  display: inline-flex;
  gap: 24rpx;
}

.child-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  padding: 16rpx 0;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.child-active {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.child-active .child-name {
  color: #fff;
}

.child-avatar {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.child-name {
  font-size: 22rpx;
  color: #2C3E50;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100rpx;
}

.child-add {
  border: 2rpx dashed #C0C0C0;
  background: transparent;
  box-shadow: none;
}

/* 通用 section */
.section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2C3E50;
}

.add-btn {
  font-size: 26rpx;
  color: #2ECC71;
  font-weight: 500;
  padding: 6rpx 16rpx;
}

/* 单词本列表 */
.book-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.book-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.book-card:active {
  transform: scale(0.98);
}

.book-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.book-info {
  flex: 1;
}

.book-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2C3E50;
}

.book-count {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 4rpx;
}

.book-arrow {
  font-size: 36rpx;
  color: #C0C0C0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 26rpx;
  color: #95A5A6;
}
