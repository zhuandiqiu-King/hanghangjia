<view class="vocab-page">
  <!-- 小朋友选择区 -->
  <view class="child-section">
    <scroll-view class="child-scroll" scroll-x>
      <view class="child-list">
        <view
          wx:for="{{children}}"
          wx:key="id"
          class="child-item {{currentChild && currentChild.id === item.id ? 'child-active' : ''}}"
          bindtap="selectChild"
          data-id="{{item.id}}"
        >
          <text class="child-avatar">{{item.avatar}}</text>
          <text class="child-name">{{item.name}}</text>
        </view>
        <view class="child-item child-add" bindtap="showAddChild">
          <text class="child-avatar">➕</text>
          <text class="child-name">添加</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 单词本列表 -->
  <view wx:if="{{currentChild}}" class="section">
    <view class="section-header">
      <text class="section-title">{{currentChild.name}}的单词本</text>
      <view class="add-btn" bindtap="showAddBook">
        <text>+ 新建</text>
      </view>
    </view>

    <view wx:if="{{wordbooks.length}}" class="book-list">
      <view
        wx:for="{{wordbooks}}"
        wx:key="id"
        class="book-card"
        bindtap="goToBook"
        data-id="{{item.id}}"
        bindlongpress="onBookLongPress"
        data-name="{{item.name}}"
      >
        <view class="book-icon">📘</view>
        <view class="book-info">
          <text class="book-name">{{item.name}}</text>
          <text class="book-count">{{item.word_count}} 个单词</text>
        </view>
        <view class="book-arrow">›</view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">📚</text>
      <text class="empty-text">还没有单词本，点击上方新建</text>
    </view>
  </view>

  <!-- 未选择小朋友 -->
  <view wx:else class="empty-state" style="margin-top: 120rpx;">
    <text class="empty-icon">👦</text>
    <text class="empty-text">请先添加一个小朋友</text>
  </view>
</view>
