.dictation-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

/* ===== 设置步骤 ===== */
.step-setup {
  padding-top: 24rpx;
}

.setup-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 32rpx;
}

.setup-section {
  margin-bottom: 32rpx;
}

.setup-label {
  display: block;
  font-size: 26rpx;
  color: #7F8C8D;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.option-row {
  display: flex;
  gap: 16rpx;
}

.option-row-wrap {
  flex-wrap: wrap;
}

.option-item {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2C3E50;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.option-active {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.random-count {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2C3E50;
}

.count-input {
  width: 120rpx;
  height: 64rpx;
  text-align: center;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin: 0 12rpx;
}

.count-unit {
  color: #7F8C8D;
}

.start-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.3);
}

.start-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ===== 听写进行中 ===== */
.step-doing {
  padding-top: 16rpx;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2ECC71, #27AE60);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.question-label {
  display: block;
  font-size: 26rpx;
  color: #95A5A6;
  margin-bottom: 24rpx;
}

.play-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
}

.play-btn:active {
  opacity: 0.7;
}

.play-icon {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}

.play-text {
  font-size: 24rpx;
  color: #2ECC71;
  font-weight: 500;
}

/* 作答区 */
.answer-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.answer-input {
  height: 88rpx;
  padding: 0 28rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  color: #2C3E50;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.next-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.next-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 语音模式 */
.voice-status-bar {
  text-align: center;
  margin-bottom: 8rpx;
}

.voice-status-text {
  font-size: 26rpx;
  color: #95A5A6;
  font-weight: 500;
}

.status-playing {
  color: #3498DB;
}

.status-recording {
  color: #E74C3C;
}

.status-recognizing {
  color: #F39C12;
}

.voice-answer-display {
  min-height: 120rpx;
  padding: 32rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-answer-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #2C3E50;
}

.voice-answer-placeholder {
  font-size: 28rpx;
  color: #C0C0C0;
}

/* 录音波形动画 */
.voice-wave {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  padding: 16rpx 0;
}

.wave-bar {
  width: 8rpx;
  height: 32rpx;
  background: #E74C3C;
  border-radius: 4rpx;
  animation: waveAnim 0.8s ease-in-out infinite;
}

.wave-bar:nth-child(1) { animation-delay: 0s; }
.wave-bar:nth-child(2) { animation-delay: 0.15s; }
.wave-bar:nth-child(3) { animation-delay: 0.3s; }
.wave-bar:nth-child(4) { animation-delay: 0.15s; }
.wave-bar:nth-child(5) { animation-delay: 0s; }

@keyframes waveAnim {
  0%, 100% { height: 16rpx; }
  50% { height: 56rpx; }
}

/* 底部操作 */
.voice-bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.voice-replay-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #3498DB;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.voice-replay-btn:active {
  opacity: 0.7;
}

.voice-skip-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #E74C3C;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.voice-skip-btn:active {
  opacity: 0.7;
}
