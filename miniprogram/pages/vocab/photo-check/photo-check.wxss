.photo-check-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

/* ===== 播报步骤 ===== */
.play-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.play-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.play-progress {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-bottom: 32rpx;
}

.play-current {
  margin-bottom: 24rpx;
}

.play-word {
  font-size: 40rpx;
}

.play-hint {
  display: block;
  font-size: 26rpx;
  color: #7F8C8D;
}

.play-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
}

/* ===== 拍照步骤 ===== */
.step-photo {
  padding-top: 24rpx;
}

.photo-tip {
  margin-bottom: 20rpx;
}

.tip-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #2C3E50;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed #C0C0C0;
}

.upload-area:active {
  background: #F8F8F8;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.preview-wrap {
  margin-top: 16rpx;
}

.preview-img {
  width: 100%;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

/* ===== 加载 ===== */
.step-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #2ECC71;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #7F8C8D;
}

/* ===== 批改结果 ===== */
.score-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
}

.score-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C3E50;
}

.score-hint {
  font-size: 22rpx;
  color: #95A5A6;
}

.check-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.check-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.check-status {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.check-correct .check-status {
  background: #E8F8F0;
  color: #2ECC71;
}

.check-wrong .check-status {
  background: #FDEDEE;
  color: #E74C3C;
}

.check-content {
  flex: 1;
}

.check-word {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2C3E50;
}

.check-meaning {
  display: block;
  font-size: 24rpx;
  color: #7F8C8D;
  margin-top: 4rpx;
}

.check-answer-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.check-label {
  font-size: 22rpx;
  color: #95A5A6;
  flex-shrink: 0;
}

.check-answer-input {
  flex: 1;
  height: 48rpx;
  padding: 0 12rpx;
  background: #F8F6F3;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #2C3E50;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* ===== 通用按钮 ===== */
.btn-primary,
.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.btn-secondary {
  background: #fff;
  color: #2C3E50;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary:active,
.btn-secondary:active {
  opacity: 0.85;
  transform: scale(0.98);
}
