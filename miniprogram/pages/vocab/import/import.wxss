.import-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

/* 拍照步骤 */
.photo-tip {
  padding: 32rpx 0 24rpx;
}

.tip-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #2C3E50;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed #C0C0C0;
  margin-top: 16rpx;
}

.upload-area:active {
  background: #F8F8F8;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #95A5A6;
}

/* 预览 */
.preview-wrap {
  margin-top: 16rpx;
}

.preview-img {
  width: 100%;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

/* 加载中 */
.step-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #2ECC71;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #7F8C8D;
}

/* 确认步骤 */
.confirm-header {
  padding: 28rpx 0 20rpx;
}

.confirm-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #2C3E50;
}

.confirm-desc {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 6rpx;
}

/* 单词编辑列表 */
.word-edit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.word-edit-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.word-edit-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 22rpx;
  color: #95A5A6;
  background: #F5F0EB;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.word-edit-fields {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.edit-input {
  height: 56rpx;
  padding: 0 16rpx;
  background: #F8F6F3;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #2C3E50;
}

.word-edit-del {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #E74C3C;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 底部操作 */
.confirm-actions {
  display: flex;
  gap: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 通用按钮 */
.btn-primary,
.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 204, 113, 0.3);
}

.btn-secondary {
  background: #fff;
  color: #2C3E50;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary:active,
.btn-secondary:active {
  opacity: 0.85;
  transform: scale(0.98);
}
