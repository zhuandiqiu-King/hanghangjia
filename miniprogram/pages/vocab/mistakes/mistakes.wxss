.mistakes-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

.mistake-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0 16rpx;
}

.mistake-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2C3E50;
}

.retry-all-btn {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.retry-all-btn:active {
  opacity: 0.85;
}

.mistake-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mistake-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.mistake-count-badge {
  width: 64rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 20rpx;
  color: #E74C3C;
  background: #FDEDEE;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  font-weight: 500;
}

.mistake-content {
  flex: 1;
}

.mistake-en {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2C3E50;
}

.mistake-cn {
  display: block;
  font-size: 24rpx;
  color: #7F8C8D;
  margin-top: 4rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #95A5A6;
}
