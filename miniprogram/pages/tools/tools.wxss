.tools-page {
  min-height: 100vh;
  background: #F5F0EB;
  padding: 0 28rpx 40rpx;
}

/* 页面标题 */
.page-header {
  padding: 36rpx 4rpx 28rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 6rpx;
}

/* 分类卡片 */
.category-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.category-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2C3E50;
}

/* 工具网格 — 三列 */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
}

.tool-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 24rpx;
  position: relative;
  transition: opacity 0.2s;
}

.tool-item:active {
  opacity: 0.7;
}

.tool-disabled {
  opacity: 0.4;
}

/* 图标 */
.tool-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8F8F0, #D4EFDF);
  border-radius: 24rpx;
  margin-bottom: 12rpx;
}

.tool-icon {
  font-size: 40rpx;
}

/* 即将上线小圆点 */
.coming-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #F39C12;
  border: 3rpx solid #fff;
}

.tool-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #2C3E50;
  margin-bottom: 4rpx;
}

.tool-desc {
  font-size: 20rpx;
  color: #B0B0B0;
}
