<view class="login-page">
  <view class="logo-area">
    <text class="logo-icon">🌱</text>
    <text class="logo-title">Plant Sprite</text>
    <text class="logo-desc">你的家庭生活小助手</text>
  </view>

  <!-- 头像 + 昵称 -->
  <view class="profile-area">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">
        <text class="avatar-placeholder-text">点击选择头像</text>
      </view>
    </button>
    <input
      class="nickname-input"
      type="nickname"
      placeholder="点击获取微信昵称"
      value="{{nickname}}"
      bindinput="onNicknameInput"
    />
  </view>

  <button class="login-btn" bindtap="handleLogin" loading="{{loading}}">
    微信授权登录
  </button>
</view>
