.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  margin-top: 16rpx;
}

.reminder-section {
  background: #fff3e0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.reminder-section .section-title {
  margin-top: 0;
  color: #e65100;
}

.reminder-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.reminder-item {
  background: #fff;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ff9800;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #07c160;
  color: #fff;
  font-size: 56rpx;
  border-radius: 50%;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
}

.fab:active {
  transform: scale(0.95);
}
