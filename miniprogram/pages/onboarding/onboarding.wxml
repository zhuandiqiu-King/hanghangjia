<view class="onboarding-page">
  <!-- 装饰背景 -->
  <view class="deco-bg">
    <view class="deco-circle deco-circle-1"></view>
    <view class="deco-circle deco-circle-2"></view>
  </view>

  <view class="content">
    <text class="welcome-text">欢迎来到夯夯家 🏠</text>
    <text class="welcome-sub">完善你的个人信息吧</text>

    <!-- 头像选择 -->
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{realAvatar}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-emoji">{{emojiAvatar}}</view>
      </button>
      <text class="avatar-hint">点击更换头像</text>
    </view>

    <!-- 昵称输入 -->
    <view class="nickname-section">
      <text class="field-label">昵称</text>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="输入你的昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <!-- 按钮区 -->
    <button class="save-btn" bindtap="handleSave" loading="{{saving}}">完善信息</button>
    <view class="skip-btn" bindtap="handleSkip">稍后再说</view>
  </view>
</view>
