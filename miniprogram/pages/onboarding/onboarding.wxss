.onboarding-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #E8F8F0 0%, #F5F0EB 50%, #FFFFFF 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰圆 */
.deco-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
}

.deco-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(46, 204, 113, 0.08), transparent);
  top: -100rpx;
  right: -100rpx;
}

.deco-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(243, 156, 18, 0.06), transparent);
  bottom: 200rpx;
  left: -80rpx;
}

.content {
  position: relative;
  z-index: 1;
  flex: 1;
  padding: 60rpx 40rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.welcome-text {
  display: block;
  text-align: center;
  font-size: 44rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.welcome-sub {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #95A5A6;
  margin-bottom: 48rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
  border: 4rpx solid #A8E6CF;
}

.avatar-emoji {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F0, #A8E6CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  border: 4rpx dashed #2ECC71;
}

.avatar-hint {
  font-size: 22rpx;
  color: #95A5A6;
  margin-top: 12rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.field-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.field-row:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 28rpx;
  color: #2C3E50;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.field-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #2C3E50;
  text-align: right;
}

.field-input-right {
  flex: 1;
  height: 60rpx;
  font-size: 26rpx;
  color: #95A5A6;
  text-align: right;
}

.field-value {
  display: flex;
  align-items: center;
  margin-left: auto;
  font-size: 26rpx;
  color: #95A5A6;
}

.arrow {
  font-size: 32rpx;
  color: #BDC3C7;
  margin-left: 8rpx;
}

.custom-wrap {
  padding: 12rpx 0;
}

.custom-wrap .field-input {
  text-align: left;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 72rpx;
}

/* 按钮 */
.save-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.35);
  letter-spacing: 4rpx;
  margin-top: 16rpx;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.skip-btn {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #95A5A6;
  text-align: center;
  padding: 16rpx;
}

.skip-btn:active {
  color: #2C3E50;
}

.bottom-space {
  height: 60rpx;
}
