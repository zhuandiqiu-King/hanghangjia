.onboarding-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F8F0 0%, #F5F0EB 50%, #FFFFFF 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰圆 */
.deco-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
}

.deco-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(46, 204, 113, 0.08), transparent);
  top: -100rpx;
  right: -100rpx;
}

.deco-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(243, 156, 18, 0.06), transparent);
  bottom: 200rpx;
  left: -80rpx;
}

.content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.welcome-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: #95A5A6;
  margin-bottom: 60rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  overflow: hidden;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: block;
  border: 4rpx solid #A8E6CF;
}

.avatar-emoji {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8F0, #A8E6CF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  border: 4rpx dashed #2ECC71;
}

.avatar-hint {
  font-size: 22rpx;
  color: #95A5A6;
  margin-top: 12rpx;
}

/* 昵称 */
.nickname-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #95A5A6;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #2C3E50;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

/* 按钮 */
.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.35);
  letter-spacing: 4rpx;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.skip-btn {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #95A5A6;
  text-align: center;
  padding: 16rpx;
}

.skip-btn:active {
  color: #2C3E50;
}
