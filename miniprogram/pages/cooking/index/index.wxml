<view class="cooking-page">
  <!-- 头部 -->
  <view class="page-header">
    <text class="header-title">烹饪助手</text>
    <text class="header-action" bindtap="goFavorites">我的收藏</text>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索菜谱 / 食材"
      confirm-type="search"
      bindconfirm="onSearch"
      value="{{keyword}}"
    />
  </view>

  <!-- 分类 -->
  <view class="category-section">
    <scroll-view scroll-x class="category-scroll">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-tag {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >
        <text class="tag-icon">{{item.icon}}</text>
        <text class="tag-name">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 菜谱列表 -->
  <view class="recipe-grid">
    <view
      wx:for="{{recipes}}"
      wx:key="id"
      class="recipe-card"
      bindtap="onRecipeTap"
      data-id="{{item.id}}"
    >
      <view class="recipe-cover">
        <image wx:if="{{item.cover_image}}" src="{{item.cover_image}}" mode="aspectFill" class="cover-img" />
        <view wx:else class="cover-placeholder">
          <text class="placeholder-icon">🍳</text>
        </view>
        <view class="recipe-time" wx:if="{{item.cook_time}}">
          <text>⏱ {{item.cook_time}}min</text>
        </view>
      </view>
      <view class="recipe-info">
        <text class="recipe-name">{{item.name}}</text>
        <view class="recipe-meta">
          <text class="recipe-difficulty">{{difficultyMap[item.difficulty] || '简单'}}</text>
          <view class="recipe-fav" catchtap="onFavoriteTap" data-id="{{item.id}}">
            <text>{{item.is_favorited ? '❤️' : '🤍'}} {{item.favorite_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view wx:if="{{!loading && !hasMore && recipes.length > 0}}" class="loading-tip">没有更多了</view>
  <view wx:if="{{!loading && recipes.length === 0}}" class="empty-state">
    <text class="empty-icon">🍳</text>
    <text class="empty-text">暂无菜谱</text>
  </view>
</view>
