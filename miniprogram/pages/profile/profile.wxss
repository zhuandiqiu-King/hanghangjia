.profile-page {
  min-height: 100vh;
  background: #f0f5f0;
  padding-bottom: 40rpx;
}

/* 头像区域 */
.user-header {
  background: linear-gradient(135deg, #66bb6a, #43a047);
  padding: 60rpx 0 50rpx;
  text-align: center;
}

.avatar-wrap {
  margin: 0 auto 20rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 分区 */
.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 26rpx;
  color: #666;
  padding: 24rpx 28rpx 12rpx;
  font-weight: bold;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #333;
}

.item-value {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* 称呼输入 */
.nickname-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #666;
}

/* 自定义角色输入 */
.custom-input-wrap {
  padding: 0 28rpx 24rpx;
}

.custom-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 退出登录 */
.logout-item .item-label {
  color: #e53935;
}

/* 保存按钮 */
.save-btn-wrap {
  padding: 20rpx 28rpx 28rpx;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

.save-btn:active {
  opacity: 0.85;
}
