.container {
  padding: 24rpx;
  background: #F5F0EB;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2C3E50;
}

.batch-btn {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.batch-btn:active {
  opacity: 0.85;
}

.item-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.item-row:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  border: 3rpx solid #BDC3C7;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
}

.check-box.selected {
  background: #2ECC71;
  border-color: #2ECC71;
  color: #fff;
}

.item-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  color: #2C3E50;
}

.item-count {
  font-size: 22rpx;
  color: #95A5A6;
  margin-top: 4rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.quick-add {
  font-size: 24rpx;
  color: #3498DB;
  padding: 8rpx 16rpx;
  background: rgba(52, 152, 219, 0.1);
  border-radius: 12rpx;
}

.quick-add:active {
  opacity: 0.7;
}

.delete-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #BDC3C7;
}

.delete-btn:active {
  color: #E74C3C;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #95A5A6;
}
