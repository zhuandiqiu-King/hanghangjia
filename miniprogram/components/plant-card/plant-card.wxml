<view class="card" bindtap="onTap">
  <view class="card-header">
    <text class="plant-name">{{plant.name}}</text>
    <text class="plant-category">{{plant.category === 'indoor' ? '室内' : '室外'}}</text>
  </view>
  <view class="card-body">
    <text class="interval">每 {{plant.watering_interval}} 天浇水</text>
    <text class="status {{statusClass}}">{{statusText}}</text>
  </view>
</view>
